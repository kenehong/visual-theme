    "radiusLg": "4px",
    "radiusFull": "9999px",
    "borderWidth": "2px"
  },
  "typography": {
    "fontSans": "'Inter', -apple-system, 'Segoe UI', sans-serif",
    "fontMono": "'JetBrains Mono', 'SF Mono', monospace",
    "fontDisplay": "'Archivo', 'Inter', 'Helvetica Neue', sans-serif",
    "weightNormal": 400,
    "weightMedium": 500,
    "weightBold": 700,
    "letterSpacingHeading": "-0.01em",
